{
  "doctype": "DocType",
  "name": "Pharma Sample Ledger",
  "module": "Pharma Quick Sale",
  "custom": 0,
  "autoname": "PH-SLED-.YYYY.-.#####",
  "title_field": "sales_person",
  "fields": [
    {
      "fieldname": "posting_date",
      "fieldtype": "Date",
      "label": "Posting Date",
      "default": "Today",
      "in_list_view": 1
    },
    {
      "fieldname": "sales_person",
      "fieldtype": "Link",
      "label": "MR / Sales Person",
      "options": "Sales Person",
      "reqd": 1,
      "in_list_view": 1
    },
    {
      "fieldname": "item_code",
      "fieldtype": "Link",
      "label": "Sample Item",
      "options": "Item",
      "reqd": 1,
      "in_list_view": 1
    },
    {
      "fieldname": "batch_no",
      "fieldtype": "Link",
      "label": "Batch",
      "options": "Batch",
      "in_list_view": 1
    },
    {
      "fieldname": "expiry_date",
      "fieldtype": "Date",
      "label": "Expiry Date"
    },
    {
      "fieldname": "transaction_type",
      "fieldtype": "Select",
      "label": "Transaction Type",
      "options": "Opening\nIssued\nDistributed\nReturned\nExpired\nAdjustment",
      "reqd": 1,
      "in_list_view": 1
    },
    {
      "fieldname": "qty",
      "fieldtype": "Float",
      "label": "Qty",
      "reqd": 1,
      "in_list_view": 1
    },
    {
      "fieldname": "reference_doctype",
      "fieldtype": "Data",
      "label": "Reference DocType"
    },
    {
      "fieldname": "reference_name",
      "fieldtype": "Dynamic Link",
      "label": "Reference Name",
      "options": "reference_doctype"
    }
  ],
  "permissions": [
    {
      "role": "System Manager",
      "read": 1,
      "write": 1,
      "create": 1,
      "delete": 1,
      "submit": 1,
      "cancel": 1
    },
    {
      "role": "Sales Manager",
      "read": 1,
      "write": 1,
      "create": 1,
      "submit": 1
    },
    {
      "role": "Pharma SFA Manager",
      "read": 1,
      "write": 1,
      "create": 1,
      "submit": 1
    },
    {
      "role": "Pharma MR",
      "read": 1,
      "write": 1,
      "create": 1
    }
  ]
}