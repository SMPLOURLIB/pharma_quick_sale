{
  "doctype": "DocType",
  "name": "Pharma Product Substitute",
  "module": "Pharma Quick Sale",
  "custom": 0,
  "autoname": "format:{item_code}-{substitute_item}",
  "title_field": "item_code",
  "fields": [
    {
      "fieldname": "item_code",
      "fieldtype": "Link",
      "label": "Item",
      "options": "Item",
      "reqd": 1,
      "in_list_view": 1
    },
    {
      "fieldname": "substitute_item",
      "fieldtype": "Link",
      "label": "Substitute Item",
      "options": "Item",
      "reqd": 1,
      "in_list_view": 1
    },
    {
      "fieldname": "priority",
      "fieldtype": "Int",
      "label": "Priority",
      "default": 10,
      "in_list_view": 1
    },
    {
      "fieldname": "reason",
      "fieldtype": "Small Text",
      "label": "Reason"
    },
    {
      "fieldname": "active",
      "fieldtype": "Check",
      "label": "Active",
      "default": 1
    }
  ],
  "permissions": [
    {
      "role": "System Manager",
      "read": 1,
      "write": 1,
      "create": 1,
      "delete": 1,
      "submit": 1,
      "cancel": 1
    },
    {
      "role": "Sales Manager",
      "read": 1,
      "write": 1,
      "create": 1,
      "submit": 1
    },
    {
      "role": "Sales User",
      "read": 1
    }
  ]
}