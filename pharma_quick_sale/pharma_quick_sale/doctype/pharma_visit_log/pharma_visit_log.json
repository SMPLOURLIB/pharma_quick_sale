{
  "doctype": "DocType",
  "name": "Pharma Visit Log",
  "module": "Pharma Quick Sale",
  "custom": 0,
  "autoname": "PH-VISIT-.YYYY.-.#####",
  "title_field": "sales_person",
  "is_submittable": 1,
  "fields": [
    {
      "fieldname": "visit_date",
      "fieldtype": "Date",
      "label": "Visit Date",
      "default": "Today",
      "reqd": 1,
      "in_list_view": 1
    },
    {
      "fieldname": "sales_person",
      "fieldtype": "Link",
      "label": "MR / Sales Person",
      "options": "Sales Person",
      "reqd": 1,
      "in_list_view": 1
    },
    {
      "fieldname": "beat_plan",
      "fieldtype": "Link",
      "label": "Beat Plan",
      "options": "Pharma Beat Plan"
    },
    {
      "fieldname": "doctor",
      "fieldtype": "Link",
      "label": "Doctor",
      "options": "Pharma Doctor",
      "in_list_view": 1
    },
    {
      "fieldname": "customer",
      "fieldtype": "Link",
      "label": "Chemist / Distributor",
      "options": "Customer"
    },
    {
      "fieldname": "visit_status",
      "fieldtype": "Select",
      "label": "Visit Status",
      "options": "Scheduled\nCompleted\nMissed\nCancelled",
      "default": "Scheduled",
      "in_list_view": 1
    },
    {
      "fieldname": "check_in_time",
      "fieldtype": "Datetime",
      "label": "Check-in"
    },
    {
      "fieldname": "check_out_time",
      "fieldtype": "Datetime",
      "label": "Check-out"
    },
    {
      "fieldname": "latitude",
      "fieldtype": "Float",
      "label": "Latitude"
    },
    {
      "fieldname": "longitude",
      "fieldtype": "Float",
      "label": "Longitude"
    },
    {
      "fieldname": "dcr",
      "fieldtype": "Link",
      "label": "DCR",
      "options": "Pharma DCR"
    },
    {
      "fieldname": "samples_given",
      "fieldtype": "Float",
      "label": "Samples Given"
    },
    {
      "fieldname": "order_value",
      "fieldtype": "Currency",
      "label": "Order Value"
    },
    {
      "fieldname": "remarks",
      "fieldtype": "Small Text",
      "label": "Remarks"
    }
  ],
  "permissions": [
    {
      "role": "System Manager",
      "read": 1,
      "write": 1,
      "create": 1,
      "delete": 1,
      "submit": 1,
      "cancel": 1
    },
    {
      "role": "Sales Manager",
      "read": 1,
      "write": 1,
      "create": 1,
      "submit": 1,
      "cancel": 1
    },
    {
      "role": "Sales User",
      "read": 1,
      "write": 1,
      "create": 1
    },
    {
      "role": "Pharma MR",
      "read": 1,
      "write": 1,
      "create": 1
    }
  ]
}