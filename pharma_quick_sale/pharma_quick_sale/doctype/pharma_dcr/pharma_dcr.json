{
  "doctype": "DocType",
  "name": "Pharma DCR",
  "module": "Pharma Quick Sale",
  "custom": 0,
  "is_submittable": 1,
  "autoname": "PH-DCR-.YYYY.-.#####",
  "title_field": "sales_person",
  "fields": [
    {
      "fieldname": "dcr_date",
      "fieldtype": "Date",
      "label": "DCR Date",
      "default": "Today",
      "reqd": 1,
      "in_list_view": 1
    },
    {
      "fieldname": "sales_person",
      "fieldtype": "Link",
      "label": "MR / Sales Person",
      "options": "Sales Person",
      "reqd": 1,
      "in_list_view": 1
    },
    {
      "fieldname": "manager",
      "fieldtype": "Link",
      "label": "Manager",
      "options": "Sales Person"
    },
    {
      "fieldname": "territory",
      "fieldtype": "Link",
      "label": "Territory",
      "options": "Territory",
      "in_list_view": 1
    },
    {
      "fieldname": "status",
      "fieldtype": "Select",
      "label": "Status",
      "options": "Draft\nSubmitted\nApproved\nRejected",
      "default": "Draft",
      "in_list_view": 1
    },
    {
      "fieldname": "doctor",
      "fieldtype": "Link",
      "label": "Doctor",
      "options": "Pharma Doctor",
      "reqd": 1,
      "in_list_view": 1
    },
    {
      "fieldname": "visit_type",
      "fieldtype": "Select",
      "label": "Visit Type",
      "options": "Planned\nUnplanned\nFollow-up\nCamp\nPhone Call",
      "default": "Planned"
    },
    {
      "fieldname": "visit_time",
      "fieldtype": "Datetime",
      "label": "Visit Time"
    },
    {
      "fieldname": "products_promoted",
      "fieldtype": "Table",
      "label": "Products Promoted",
      "options": "Pharma Promoted Product"
    },
    {
      "fieldname": "samples_given",
      "fieldtype": "Table",
      "label": "Samples Given",
      "options": "Pharma Sample Line"
    },
    {
      "fieldname": "order_value",
      "fieldtype": "Currency",
      "label": "Order Value"
    },
    {
      "fieldname": "competitor_feedback",
      "fieldtype": "Small Text",
      "label": "Competitor Feedback"
    },
    {
      "fieldname": "doctor_feedback",
      "fieldtype": "Small Text",
      "label": "Doctor Feedback"
    },
    {
      "fieldname": "next_followup_date",
      "fieldtype": "Date",
      "label": "Next Follow-up Date"
    },
    {
      "fieldname": "latitude",
      "fieldtype": "Float",
      "label": "Latitude"
    },
    {
      "fieldname": "longitude",
      "fieldtype": "Float",
      "label": "Longitude"
    }
  ],
  "permissions": [
    {
      "role": "System Manager",
      "read": 1,
      "write": 1,
      "create": 1,
      "delete": 1,
      "submit": 1,
      "cancel": 1
    },
    {
      "role": "Sales Manager",
      "read": 1,
      "write": 1,
      "create": 1,
      "delete": 0,
      "submit": 1,
      "cancel": 1
    },
    {
      "role": "Sales User",
      "read": 1,
      "write": 1,
      "create": 1,
      "delete": 0,
      "submit": 1,
      "cancel": 0
    }
  ]
}