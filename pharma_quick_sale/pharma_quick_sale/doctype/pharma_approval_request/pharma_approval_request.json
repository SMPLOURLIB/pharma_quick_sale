{
  "doctype": "DocType",
  "name": "Pharma Approval Request",
  "module": "Pharma Quick Sale",
  "custom": 0,
  "is_submittable": 1,
  "autoname": "PH-APR-.YYYY.-.#####",
  "title_field": "approval_type",
  "fields": [
    {
      "fieldname": "approval_type",
      "fieldtype": "Select",
      "label": "Approval Type",
      "options": "Credit Override\nScheme Override\nReturn Approval\nClaim Approval\nLicense Override",
      "reqd": 1,
      "in_list_view": 1
    },
    {
      "fieldname": "status",
      "fieldtype": "Select",
      "label": "Status",
      "options": "Pending\nApproved\nRejected",
      "default": "Pending",
      "in_list_view": 1
    },
    {
      "fieldname": "requested_by",
      "fieldtype": "Link",
      "label": "Requested By",
      "options": "User",
      "default": "user",
      "in_list_view": 1
    },
    {
      "fieldname": "approved_by",
      "fieldtype": "Link",
      "label": "Approved By",
      "options": "User"
    },
    {
      "fieldname": "reference_doctype",
      "fieldtype": "Data",
      "label": "Reference DocType"
    },
    {
      "fieldname": "reference_name",
      "fieldtype": "Dynamic Link",
      "label": "Reference Name",
      "options": "reference_doctype"
    },
    {
      "fieldname": "reason",
      "fieldtype": "Small Text",
      "label": "Reason"
    },
    {
      "fieldname": "decision_notes",
      "fieldtype": "Small Text",
      "label": "Decision Notes"
    }
  ],
  "permissions": [
    {
      "role": "System Manager",
      "read": 1,
      "write": 1,
      "create": 1,
      "submit": 1,
      "cancel": 1
    },
    {
      "role": "Sales Manager",
      "read": 1,
      "write": 1,
      "create": 1,
      "submit": 1
    },
    {
      "role": "Sales User",
      "read": 1,
      "create": 1
    }
  ]
}