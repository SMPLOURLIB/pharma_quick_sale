{
  "doctype": "DocType",
  "name": "Pharma MR Expense Claim",
  "module": "Pharma Quick Sale",
  "custom": 0,
  "is_submittable": 1,
  "autoname": "PH-EXP-.YYYY.-.#####",
  "title_field": "sales_person",
  "fields": [
    {
      "fieldname": "posting_date",
      "fieldtype": "Date",
      "label": "Posting Date",
      "default": "Today",
      "reqd": 1,
      "in_list_view": 1
    },
    {
      "fieldname": "sales_person",
      "fieldtype": "Link",
      "label": "MR / Sales Person",
      "options": "Sales Person",
      "reqd": 1,
      "in_list_view": 1
    },
    {
      "fieldname": "claim_status",
      "fieldtype": "Select",
      "label": "Claim Status",
      "options": "Draft\nSubmitted\nApproved\nRejected\nPaid",
      "default": "Draft",
      "in_list_view": 1
    },
    {
      "fieldname": "items",
      "fieldtype": "Table",
      "label": "Expense Items",
      "options": "Pharma MR Expense Item"
    },
    {
      "fieldname": "total_claimed",
      "fieldtype": "Currency",
      "label": "Total Claimed",
      "read_only": 1,
      "in_list_view": 1
    },
    {
      "fieldname": "approved_amount",
      "fieldtype": "Currency",
      "label": "Approved Amount"
    }
  ],
  "permissions": [
    {
      "role": "System Manager",
      "read": 1,
      "write": 1,
      "create": 1,
      "delete": 1,
      "submit": 1,
      "cancel": 1
    },
    {
      "role": "Sales Manager",
      "read": 1,
      "write": 1,
      "create": 1,
      "delete": 0,
      "submit": 1,
      "cancel": 1
    },
    {
      "role": "Sales User",
      "read": 1,
      "write": 1,
      "create": 1,
      "delete": 0,
      "submit": 1,
      "cancel": 0
    }
  ]
}