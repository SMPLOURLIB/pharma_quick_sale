{
  "doctype": "DocType",
  "name": "Pharma Customer Product Stats",
  "module": "Pharma Quick Sale",
  "custom": 0,
  "autoname": "format:{customer}-{item_code}",
  "title_field": "customer",
  "fields": [
    {
      "fieldname": "customer",
      "fieldtype": "Link",
      "label": "Customer",
