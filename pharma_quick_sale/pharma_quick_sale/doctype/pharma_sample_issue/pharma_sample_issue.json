      "in_list_view": 1
    },
    {
      "fieldname": "sales_person",
      "fieldtype": "Link",
      "label": "MR / Sales Person",
      "options": "Sales Person",
      "reqd": 1,
      "in_list_view": 1
    },
    {
      "fieldname": "source_warehouse",
      "fieldtype": "Link",
      "label": "Source Warehouse",
      "options": "Warehouse",
      "reqd": 1
    },
    {
      "fieldname": "status",
      "fieldtype": "Select",
